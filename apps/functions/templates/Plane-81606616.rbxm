			<Item class="Script" referent="RBX2">
				<Properties>
					<bool name="Disabled">false</bool>
					<Content name="LinkedSource"><null></null></Content>
					<string name="Name">READ ME FIRST</string>
					<ProtectedString name="Source">--Made by iceflare
--In order for this to work, please group it with the bricks that need regening
--A player must step on/touch the regen button for those bricks to regen

model = script.Parent.Parent
messageText = &quot;regening&quot;--If you want a message when someone regens something, put it here

message = Instance.new(&quot;Message&quot;)
message.Text = messageText
backup = model:clone()
enabled = true

function regenerate()
&#9;message.Parent = game.Workspace
&#9;model:remove()

&#9;wait(2)--Only change this if you have a message when regening (that would be how many seconds the message appears for)

&#9;model = backup:clone()
&#9;model.Parent = game.Workspace
&#9;model:makeJoints()
&#9;message.Parent = nil

&#9;script.Disabled = true
&#9;script.Parent.BrickColor = BrickColor.new(26)--Black (when it is regening, the regen button turns this colour)
&#9;wait(3)--How many seconds it takes to regen
&#9;script.Parent.BrickColor = BrickColor.new(104)--Purple (it will change back to this colour after regening completely)
&#9;script.Disabled = false
end

function onHit(hit)
&#9;if (hit.Parent:FindFirstChild(&quot;Humanoid&quot;) ~= nil) and enabled then
&#9;&#9;regenerate()
&#9;end
end
script.Parent.Touched:connect(onHit)

--And it&apos;s done.  If there&apos;s anything wrong with this button, PM me.  -Iceflare</ProtectedString>
				</Properties>
			</Item>
		</Item>
