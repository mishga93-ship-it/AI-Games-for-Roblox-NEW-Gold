			<Item class="Script" referent="RBX102">
				<Properties>
					<bool name="Disabled">true</bool>
					<Content name="LinkedSource"><null></null></Content>
					<string name="Name">GunScript</string>
					<ProtectedString name="Source">--wait()
local ball = script.Parent
local damage = 40

function onTouched(hit)
&#9;local humanoid = hit.Parent:findFirstChild(&quot;Humanoid&quot;)
&#9;
&#9;&#9;
&#9;if hit:getMass() &lt; 1.2 * 7 then
&#9;&#9;if hit.Anchored == false then
&#9;&#9;&#9;hit:BreakJoints()
&#9;&#9;end
&#9;end
&#9;

&#9;if humanoid ~= nil then
&#9;&#9;tagHumanoid(humanoid)
&#9;&#9;humanoid:TakeDamage(damage)
&#9;&#9;wait(2)
&#9;&#9;untagHumanoid(humanoid)
&#9;end

&#9;connection:disconnect()
&#9;ball:remove()
end

function tagHumanoid(humanoid)
&#9;-- todo: make tag expire
&#9;local tag = ball:findFirstChild(&quot;creator&quot;)
&#9;if tag ~= nil then
&#9;&#9;local new_tag = tag:clone()
&#9;&#9;new_tag.Parent = humanoid
&#9;end
end


function untagHumanoid(humanoid)
&#9;if humanoid ~= nil then
&#9;&#9;local tag = humanoid:findFirstChild(&quot;creator&quot;)
&#9;&#9;if tag ~= nil then
&#9;&#9;&#9;tag.Parent = nil
&#9;&#9;end
&#9;end
end

connection = ball.Touched:connect(onTouched)
</ProtectedString>
				</Properties>
			</Item>
			<Item class="Script" referent="RBX103">
				<Properties>
					<bool name="Disabled">true</bool>
					<Content name="LinkedSource"><null></null></Content>
					<string name="Name">RocketScript</string>
					<ProtectedString name="Source">--wait()
local creator = script.Parent:findFirstChild(&quot;creator&quot;)
local move = script.Parent:findFirstChild(&quot;Move&quot;)

local active = true

function tagHumanoid(humanoid, creator)
&#9;if creator ~= nil then
&#9;&#9;local new_tag = creator:clone()
&#9;&#9;new_tag.Parent = humanoid
&#9;end
end

function onPlayerBlownUp(part, distance, creator)
&#9;if part.Name == &quot;Head&quot; then
&#9;&#9;local humanoid = part.Parent.Humanoid
&#9;&#9;tagHumanoid(humanoid, creator)
&#9;end
end

function set_Off(hit)
&#9;if active == true then
&#9;&#9;active = false
&#9;&#9;explosion = Instance.new(&quot;Explosion&quot;)
&#9;&#9;explosion.BlastRadius = 7
&#9;&#9;explosion.BlastPressure = 500000

&#9;&#9;local creator = script.Parent:findFirstChild(&quot;creator&quot;)
&#9;&#9;if creator ~= nil then
&#9;&#9;&#9;explosion.Hit:connect(function(part, distance)  onPlayerBlownUp(part, distance, creator) end)
&#9;&#9;end

&#9;&#9;explosion.Position = script.Parent.Position
&#9;&#9;explosion.Parent = game.Workspace
&#9;&#9;wait()
&#9;&#9;script.Parent:remove()
&#9;end
end
script.Parent.Touched:connect(set_Off)

for i = 1,100 do
&#9;wait()
&#9;local desired = Instance.new(&quot;Vector3Value&quot;)
&#9;desired.Value = script.Parent.CFrame.lookVector * 300

&#9;local difference = desired.Value - move.velocity

&#9;if difference.magnitude &gt;= move.velocity.magnitude then
&#9;&#9;move.velocity = move.velocity + (difference*(0.01*i))
&#9;end
end
</ProtectedString>
				</Properties>
